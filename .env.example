# Currency Symbol
NEXT_PUBLIC_CURRENCY_SYMBOL = '$'

# Supabase authentication
NEXT_PUBLIC_SUPABASE_URL = 'https://your-project.supabase.co'
NEXT_PUBLIC_SUPABASE_ANON_KEY = 'your-anon-key'

# Optional site URL used for redirects after email confirmation.
NEXT_PUBLIC_SITE_URL = 'http://localhost:3000'

# Optional hardening for trusted origins. Comma-separated.
# Example: 'http://localhost:3000,https://your-app.vercel.app,https://yourdomain.com'
SUPABASE_AUTHORIZED_ORIGINS = ''

# Roles are resolved from public.users.role with one of:
# admin | seller | user
